# ============================================================
# 東京理科大学マインクラフトサークル（仮）- 環境変数設定
# ============================================================
# このファイルをコピーして .env を作成してください:
#   cp .env.example .env
#
# .env は .gitignore に含まれており Git にはコミットされません。
# Bot Token などの機密情報を安全に管理できます。
# ============================================================

# ── メモリ設定 ───────────────────────────────────────────────
# JVM ヒープサイズ（VPS/Mac の RAM に合わせて調整）
#   Mac M1 (16GB RAM)  → MEMORY=6G
#   VPS 4GB RAM        → MEMORY=3G
#   VPS 8GB RAM        → MEMORY=6G
MEMORY=4G

# ── Paperバージョン固定（省略で自動的に最新を取得）────────────
# 特定バージョンに固定したい場合のみ設定（通常は不要）
# 例: PAPER_VERSION=1.21.4
# PAPER_VERSION=

# ── ポート設定 ───────────────────────────────────────────────
JAVA_PORT=25565
BEDROCK_PORT=19132

# ── 表示名（ログのバナー）────────────────────────────────────
# docker compose logs で表示されるサーバー名を変更したい場合に設定
# SERVER_DISPLAY_NAME=TUS Minecraft Circle

# ── デフォルトワールド設定 ───────────────────────────────────
# server.properties の level-name と bukkit.yml の default-world-name を同時に変更
# 通常は変更不要。world を mv regen したいときだけ別ワールド名を指定して再起動。
# 再生成後は元の値（world）に戻して再起動すること。
# DEFAULT_WORLD=world

# ── Discord Bot 設定（DiscordSRV 必須）──────────────────────
# Bot Token の取得方法:
#   1. https://discord.com/developers/applications でアプリを作成
#   2. Bot タブ → Reset Token でトークンを発行
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# マイクラ↔Discordのチャット同期チャンネルID
# 取得方法: Discord 設定 → 詳細設定 → 開発者モード ON
#           → 対象チャンネルを右クリック → 「IDをコピー」
DISCORD_CHANNEL_ID=your_channel_id_here

# ── playit.gg 設定（オプション・自宅Mac運用時）──────────────
# docker-compose.yml の playit セクションを有効化した場合に使用
# 初回起動で自動生成されるため、最初は空欄で OK
PLAYIT_SECRET=
