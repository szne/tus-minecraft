# ============================================================
# 東京理科大学マインクラフトサークル（仮）- .gitignore
# ============================================================

# ── Minecraft サーバーデータ（大容量・環境固有）──────────────
# ワールドデータ・ログ・キャッシュ・生成されたプラグイン設定など
# すべて ./data/ に集約されている
data/*
!data/.gitkeep

# ── playit.gg トンネル設定（シークレット含む）────────────────
playit-data/

# ── 機密情報 ─────────────────────────────────────────────────
.env
*.env.local
*.env.production

# ── ログ ─────────────────────────────────────────────────────
*.log
logs/

# ── OS ───────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ── エディタ ─────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ── Claude Code ───────────────────────────────────────────────
.claude/
